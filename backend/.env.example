# ==========================================
# BACKEND ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and update with your production values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# For Docker: Use service name 'db' instead of localhost
# Port should match DB_PORT from main .env file
DATABASE_URL=postgresql://starlink:password@db:5432/starlink_dashboard

# For local development (outside Docker):
# DATABASE_URL=postgresql://starlink:password@127.0.0.1:5434/starlink_dashboard

# ==========================================
# AZURE KEY VAULT CONFIGURATION
# ==========================================
VAULT_URL=https://your-key-vault-name.vault.azure.net
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id

# ==========================================
# JWT CONFIGURATION
# ==========================================
SECRET_KEY=CHANGE-TO-RANDOM-SECRET-KEY-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# PORT CONFIGURATION
# ==========================================
# Backend port (should match BACKEND_PORT from main .env)
BACKEND_PORT=8000

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
