# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and update with your production values
# DO NOT commit .env file to version control!

# ==========================================
# PROJECT IDENTIFICATION (For Multiple Projects on Same VM)
# ==========================================
# Unique name for this project (used for container names and volumes)
PROJECT_NAME=starlink

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_USER=starlink
DB_PASSWORD=CHANGE-TO-STRONG-PASSWORD-IN-PRODUCTION
DB_NAME=starlink_dashboard

# Database internal port (inside Docker network)
DB_PORT=5432

# Database external port (accessible from host/VM)
# NOTE: Ports 5433 and 5434 are already in use by other projects
# Using 5435 to avoid conflicts
DB_EXTERNAL_PORT=5435

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
# Backend internal port (inside Docker network)
BACKEND_PORT=8000

# Backend external port (accessible from host/VM)
# NOTE: Ports 8010 and 8020 are already in use by other projects
# Using 8030 to avoid conflicts
BACKEND_EXTERNAL_PORT=8030

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# Frontend HTTP external port
# NOTE: Port 80 is already used by nginx on the VM
# Using 8080 to avoid conflicts
FRONTEND_EXTERNAL_PORT=8080

# Frontend HTTPS external port
# Using 8443 to avoid conflicts with port 443
FRONTEND_HTTPS_PORT=8443

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Generate a strong secret key for production!
# Use: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE-TO-RANDOM-SECRET-KEY-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# AZURE KEY VAULT CONFIGURATION
# ==========================================
VAULT_URL=https://your-key-vault-name.vault.azure.net
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Comma-separated list of allowed origins
# For production with duckdns: http://your-domain.duckdns.org:8080,https://your-domain.duckdns.org:8443
# For local development: http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# FRONTEND API URLS
# ==========================================
# For production: Use your domain with port 8080 (without trailing slash)
# Examples:
#   - http://your-domain.duckdns.org:8080/api/v1
#   - http://VM-IP:8030/api/v1 (direct backend access)
REACT_APP_API_URL=http://localhost:8030/api/v1

# For production: Use your domain with port 8080 for WebSocket (without trailing slash)
# Examples:
#   - ws://your-domain.duckdns.org:8080
#   - ws://VM-IP:8030 (direct backend access)
REACT_APP_WS_URL=ws://localhost:8030
